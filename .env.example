BOT_TOKEN=telegram_bot_token_here
DATABASE_URL=sqlite:///data/activity_bot.db
# Optional, for networks where api.telegram.org is blocked.
# Supported schemes: http, https, socks5, socks5h.
# This is a regular network proxy URL, not a Telegram MTProto proxy.
# Examples: http://127.0.0.1:8118 or socks5://host.docker.internal:1081
HTTP_PROXY_URL=
